-- LOOP PRINCIPAL (CORRIGIDO)
-- ============================================
RunService.Heartbeat:Connect(function()
    if not speedEnabled then return end
    
    local character = Player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    -- Calcula velocidade final
    local finalSpeed = targetSpeed
    if multi100x then
        finalSpeed = targetSpeed * 100
    elseif multi10x then
        finalSpeed = targetSpeed * 10
    end
    
    -- SÓ APLICA SE:
    -- 1. O boost estiver ligado (boosting = true)
    -- 2. O personagem estiver ANDANDO
    if boosting and isPlayerMoving() then
        humanoid.WalkSpeed = finalSpeed
    else
        -- Se não estiver andando OU boost desligado, volta ao normal
        humanoid.WalkSpeed = 16
    end
    
    -- Atualiza HMP
    HMPLabel.Text = "HMP:" .. math.floor(humanoid.WalkSpeed)
end)

