-- ============================================
-- FUNÇÃO PARA DETECTAR SE ESTÁ ANDANDO
-- ============================================
local function isPlayerMoving()
    local character = Player.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    
    -- Verifica se alguma tecla de movimento está pressionada
    local moving = false
    moving = moving or UserInputService:IsKeyDown(Enum.KeyCode.W)
    moving = moving or UserInputService:IsKeyDown(Enum.KeyCode.A)
    moving = moving or UserInputService:IsKeyDown(Enum.KeyCode.S)
    moving = moving or UserInputService:IsKeyDown(Enum.KeyCode.D)
    moving = moving or UserInputService:IsKeyDown(Enum.KeyCode.Up)
    moving = moving or UserInputService:IsKeyDown(Enum.KeyCode.Down)
    moving = moving or UserInputService:IsKeyDown(Enum.KeyCode.Left)
    moving = moving or UserInputService:IsKeyDown(Enum.KeyCode.Right)
    
    -- Verifica se o personagem realmente tem velocidade
    local rootPart = humanoid.RootPart
    if rootPart then
        local velocity = rootPart.Velocity
        if velocity.Magnitude > 1 then
            moving = true
        end
    end
    
    return moving
end

